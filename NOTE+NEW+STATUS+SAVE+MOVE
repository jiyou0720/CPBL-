void drawUI(Player* p) {
    gotoxy(0, MAP_HEIGHT + 1);
    printf("==================================================\n");
    printf("Active Slot      : [ Slot %d ]\n", currentSlot);
    printf("Current Location : %s (%dF)\n", p->roomName, p->floor);
    printf("HP Bar           : [");
    int filled = (p->hp * 15) / p->maxHp;
    for (int i = 0; i < filled; i++) printf("#");
    for (int i = filled; i < 15; i++) printf("-");
    printf("] %d/%d\n", p->hp, p->maxHp);

    printf("Holding Hand     : [ %s ]\n", p->holdingItem);
    printf("Inventory (5 Max): ");
    int hasItem = 0;
    for (int i = 0; i < MAX_ITEMS; i++) {
        if (strlen(p->items[i]) > 0 && strcmp(p->items[i], "Empty") != 0) {
            printf("[%s] ", p->items[i]);
            hasItem = 1;
        }
    }
    if (!hasItem) printf("(Empty)");
    printf("\n");

    printf("==================================================\n");
    printf("WASD:Move | E:Loot | G:Drop Hand | I:Inventory | M:Save | J:Logs | Q:Quit\n");
}

void drawMap(Player* p) {
    gotoxy(0, 0);
    for (int y = 0; y < MAP_HEIGHT; y++) {
        for (int x = 0; x < MAP_WIDTH; x++) {
            if (x == p->x && y == p->y) {
                printf("P");
            }
            else {
                int isDroppedPrinted = 0;
                for (int d = 0; d < MAX_DROPPED_ITEMS; d++) {
                    if (p->droppedItems[d].isActive && p->floor == p->droppedItems[d].floor && x == p->droppedItems[d].x && y == p->droppedItems[d].y) {
                        printf("*");
                        isDroppedPrinted = 1;
                        break;
                    }
                }
                if (!isDroppedPrinted) {
                    printf("%c", map[p->floor - 1][y][x]);
                }
            }
        }
        printf("\n");
    }
}

void movePlayer(Player* p, char key) {
    int nx = p->x, ny = p->y;
    char lk = tolower(key);
    if (lk == 'w') ny--;
    else if (lk == 's') ny++;
    else if (lk == 'a') nx--;
    else if (lk == 'd') nx++;
    else return;

    if (nx < 0 || nx >= MAP_WIDTH || ny < 0 || ny >= MAP_HEIGHT) return;
    if (map[p->floor - 1][ny][nx] == '#') return;

    p->x = nx; p->y = ny;
    updateRoomName(p);
    checkTriggerPoints(p);
    checkJournalEvent(p);
    checkStairsEvent(p);
}

