        triggerGhostEncounter(p);
    }
    if (p->floor == 2 && p->x == 10 && p->y == 6) {
        triggerMansionPuzzle(p);
        p->y = 7;
    }
}

void checkStairsEvent(Player* p) {
    if (p->y == 1 && p->x >= 21 && p->x <= 26) {
        system("cls");
        if (p->floor == 1) { p->floor = 2; }
        else { p->floor = 1; }
        p->y = 2;
        Sleep(500);
        updateRoomName(p);
        saveToSlot(p, currentSlot);
    }
}

int confirmQuitGame() {
    gotoxy(0, MAP_HEIGHT + 11);
    printf("==================================================\n");
    printf(" Are you sure you want to quit the game? (Y/N) : ");
    while (1) {
        char ch = tolower(_getch());
        if (ch == 'y') return 1;
        if (ch == 'n') {
            gotoxy(0, MAP_HEIGHT + 11);
            printf("                                                  \n");
            printf("                                                  \n");
            return 0;
        }
    }
}

