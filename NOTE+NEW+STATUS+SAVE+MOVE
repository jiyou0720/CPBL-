// Program Entry
// ==========================
int main() {
    srand((unsigned int)time(NULL));
    system("mode con cols=100 lines=45");
    system("cls");
    hideCursor();

    Player player;
    player.roomName[0] = '\0';

    showMainMenu(&player);

    system("cls");
    drawMap(&player);
    drawUI(&player);

    // [복구 및 완성] 무한 루프 내 핵심 입력 감지 및 사망 처리 시퀀스
    while (1) {
        // 플레이어 HP가 0 이하가 되었을 때의 처리 (Bad Ending 1)
        if (player.hp <= 0) {
            system("cls");
            printf("==================================================\n");
            printf("          [💀 BAD ENDING 1: VALIANT DEATH]        \n");
            printf("==================================================\n");
            printf(" Your injuries became too severe to hold awareness.\n");
            printf(" You collapse onto the cold mansion floor...\n");
            printf(" Game Over.\n");

            unlockAchievement(&player, 2); // 'What a Shame to Die!' 업적 해제
            printf("==================================================\n");
            printf(" Press any key to return to Main Menu... ");
            _getch();

            showMainMenu(&player);
            system("cls");
            drawMap(&player);
            drawUI(&player);
        }

        // 키 입력이 있을 때만 프레임 갱신
        if (_kbhit()) {
            char ch = _getch();
            char lch = tolower(ch);

            if (lch == 'w' || lch == 'a' || lch == 's' || lch == 'd') {
                movePlayer(&player, ch);
            }
            else if (lch == 'e') {
                executeLootItem(&player);
            }
            else if (lch == 'g') {
                executeDropItem(&player);
            }
            else if (lch == 'i') {
                showInventoryMenu(&player);
            }
            else if (lch == 'm') {
                showSaveManagerMenu(&player);
            }
            else if (lch == 'j') {
                showJournalMenu(&player);
            }
            else if (lch == 'q') {
                if (confirmQuitGame()) {
                    break;
                }
                system("cls");
            }

            // 프레임 리렌더링
            drawMap(&player);
            drawUI(&player);
        }
        Sleep(30); // CPU 점유율 최적화
    }

    return 0;
}
