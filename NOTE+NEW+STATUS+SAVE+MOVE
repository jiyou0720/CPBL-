void showJournalMenu(Player* p) {
    system("cls");
    while (1) {
        printf("==================================================\n");
        printf("                COLLECTED ARCHIVE LOGS             \n");
        printf("==================================================\n");
        for (int i = 0; i < MAX_JOURNALS; i++) {
            if (p->collectedJournals[i] == 1) {
                printf("  [%2d] Old Scattered Journal Log (Found)\n", i + 1);
            }
            else {
                printf("  [%2d] ------------------------ (Locked)\n", i + 1);
            }
        }
        printf("==================================================\n");
        printf(" Enter log number to read, or press [B] to back: ");

        char input[10]; int idx = 0;
        while (1) {
            char ch = _getch();
            if (tolower(ch) == 'b') { idx = -1; break; }
            if (ch == '\r' || ch == '\n') { input[idx] = '\0'; break; }
            if (isdigit(ch) && idx < 5) { printf("%c", ch); input[idx++] = ch; }
        }
        if (idx == -1) break;

        int num = atoi(input);
        if (num >= 1 && num <= MAX_JOURNALS && p->collectedJournals[num - 1] == 1) {
            system("cls");
            printf("==================================================\n%s\n==================================================\n", journalTexts[num - 1]);
            printf(" Press any key to return... "); _getch();
        }
        system("cls");
    }
    system("cls"); drawMap(p); drawUI(p);
}

void showSaveManagerMenu(Player* p) {
    p->saveMenuOpenCount++;
    if (p->saveMenuOpenCount >= 5) {
        unlockAchievement(p, 5);
    }

    system("cls");
    while (1) {
        printf("==================================================\n");
        printf("                SAVE MANAGEMENT MENU               \n");
        printf("==================================================\n");
        printf("  1. Save Game     2. Load Game    3. Resume\n");
        printf("==================================================\n\n Choice: ");
        char choice = _getch();
        if (choice == '1') {
            saveToSlot(p, currentSlot);
            break;
        }
        else if (choice == '2') {
            printf("\n Select Slot (1-3): ");
            int ts = _getch() - '0';
            if (ts >= 1 && ts <= 3 && globalSave.slotExists[ts - 1]) {
                currentSlot = ts; *p = globalSave.playerData[ts - 1];
                break;
            }
        }
        else if (choice == '3') break;
        system("cls");
    }
    system("cls"); drawMap(p); drawUI(p);
}

