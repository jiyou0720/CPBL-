// ==========================
// In-Game Item / Trap System
// ==========================
void triggerTrap(Player* p) {
    p->trapTriggerCount++;
    p->hp -= 15;
    if (p->hp < 0) p->hp = 0;

    gotoxy(0, MAP_HEIGHT + 9);
    printf("[💥 TRAP] Stepped on a hidden floor spike! (-15 HP)     \n");

    if (p->trapTriggerCount >= 5) {
        unlockAchievement(p, 6);
    }
    Sleep(1200);
}

