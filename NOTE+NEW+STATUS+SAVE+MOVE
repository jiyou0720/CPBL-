void useElixirItem(Player* p) {
    if (p->hp == 1) {
        unlockAchievement(p, 4);
    }
    p->hp += 30;
    if (p->hp > p->maxHp) p->hp = p->maxHp;

    gotoxy(0, MAP_HEIGHT + 9);
    printf("[+ HEAL] Consumed an Elixir from inventory. (+30 HP)       \n");
    Sleep(1200);
}

// ==========================
// 아이템 줍기 전용 시스템 (E 키)
// ==========================
void executeLootItem(Player* p) {
    int actionTaken = 0;

    // 1. 바닥에 떨어진 아이템(*)이 있는지 확인
    for (int i = 0; i < MAX_DROPPED_ITEMS; i++) {
        if (p->droppedItems[i].isActive && p->floor == p->droppedItems[i].floor && p->x == p->droppedItems[i].x && p->y == p->droppedItems[i].y) {

            // 인벤토리 최대 5개 한도 빈 슬롯 찾기
            int invIdx = -1;
            for (int j = 0; j < MAX_ITEMS; j++) {
                if (strcmp(p->items[j], "Empty") == 0 || strlen(p->items[j]) == 0) {
                    invIdx = j;
                    break;
                }
            }

            if (invIdx != -1) {
                strcpy(p->items[invIdx], p->droppedItems[i].name);
                p->droppedItems[i].isActive = 0;
                gotoxy(0, MAP_HEIGHT + 9);
                printf("[🎒 LOOT] Picked up dropped [%s] into inventory.          \n", p->items[invIdx]);
                actionTaken = 1;
                saveToSlot(p, currentSlot);
                Sleep(1200);
            }
            else {
                gotoxy(0, MAP_HEIGHT + 9);
                printf("[❌ FULL] Inventory full! Cannot carry more than 5 items. \n");
                actionTaken = 1;
                Sleep(1200);
            }
            break;
        }
    }

    if (actionTaken) return;

    // 2. 맵에 무작위 스폰된 HP 회복약 확인
    for (int i = 0; i < MAX_HEAL_ITEMS; i++) {
        if (p->healSpots[i].isSpawned && p->floor == p->healSpots[i].floor && p->x == p->healSpots[i].x && p->y == p->healSpots[i].y) {

            int invIdx = -1;
            for (int j = 0; j < MAX_ITEMS; j++) {
                if (strcmp(p->items[j], "Empty") == 0 || strlen(p->items[j]) == 0) {
                    invIdx = j;
                    break;
                }
            }

            if (invIdx != -1) {
                p->healSpots[i].isSpawned = 0;
                strcpy(p->items[invIdx], "Elixir");
                gotoxy(0, MAP_HEIGHT + 9);
                printf("[🎒 LOOT] Found and stored an [Elixir] in inventory!          \n");
                actionTaken = 1;
                saveToSlot(p, currentSlot);
                Sleep(1200);
            }
            else {
                gotoxy(0, MAP_HEIGHT + 9);
                printf("[❌ FULL] Found an Elixir, but your inventory is full (5/5)!   \n");
                actionTaken = 1;
                Sleep(1200);
            }
            break;
        }
    }

    if (!actionTaken) {
        gotoxy(0, MAP_HEIGHT + 9);
        printf("[👀 EXAMINE] You searched around carefully, but nothing is here.     \n");
        Sleep(1000);
    }
}

// ==========================
// 손에 든 아이템 바닥에 버리기 (G 키)
// ==========================
void executeDropItem(Player* p) {
    if (strcmp(p->holdingItem, "None") == 0 || strlen(p->holdingItem) == 0) {
        gotoxy(0, MAP_HEIGHT + 9);
        printf("[⚠️ DROP] You are not holding any item in your hands to drop!     \n");
        Sleep(1200);
        return;
    }

    int dropIdx = -1;
    for (int d = 0; d < MAX_DROPPED_ITEMS; d++) {
        if (!p->droppedItems[d].isActive) {
            dropIdx = d;
            break;
        }
    }

    if (dropIdx != -1) {
        p->droppedItems[dropIdx].floor = p->floor;
        p->droppedItems[dropIdx].x = p->x;
        p->droppedItems[dropIdx].y = p->y;
        strcpy(p->droppedItems[dropIdx].name, p->holdingItem);
        p->droppedItems[dropIdx].isActive = 1;

        for (int i = 0; i < MAX_ITEMS; i++) {
            if (strcmp(p->items[i], p->holdingItem) == 0) {
                strcpy(p->items[i], "Empty");
                break;
            }
        }

        gotoxy(0, MAP_HEIGHT + 9);
        printf("[🗑️ DROP] Dropped [%s] onto the floor tile.                     \n", p->holdingItem);

        strcpy(p->holdingItem, "None");
        saveToSlot(p, currentSlot);
        Sleep(1200);
    }
    else {
        gotoxy(0, MAP_HEIGHT + 9);
        printf("[❌ ERROR] Floor is too full to drop any more items!            \n");
        Sleep(1200);
    }
}

// ==========================
