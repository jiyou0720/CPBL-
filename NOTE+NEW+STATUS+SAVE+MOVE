// ==========================
void showInventoryMenu(Player* p) {
    while (1) {
        system("cls");
        printf("==================================================\n");
        printf("            INVENTORY (Max Capacity: 5)           \n");
        printf("==================================================\n");
        printf("  👉 Currently Holding: [ %s ]\n", p->holdingItem);
        printf("--------------------------------------------------\n");

        for (int i = 0; i < MAX_ITEMS; i++) {
            if (strlen(p->items[i]) > 0 && strcmp(p->items[i], "Empty") != 0) {
                printf("  [%d] %s\n", i + 1, p->items[i]);
            }
            else {
                printf("  [%d] (Empty Slot)\n", i + 1);
            }
        }
        printf("==================================================\n");
        printf(" Select Slot [1-5] to Hold/Use, or [B] to return: ");

        char ch = _getch();
        if (tolower(ch) == 'b') break;
        if (ch >= '1' && ch <= '5') {
            int idx = ch - '1';
            if (strlen(p->items[idx]) == 0 || strcmp(p->items[idx], "Empty") == 0) {
                printf("\n Selected slot is empty!\n");
                Sleep(800);
                continue;
            }

            printf("\n\n [ Selected: %s ]\n", p->items[idx]);
            printf(" 1. Hold (손에 들기)   2. Use (아이템 사용)   3. Cancel\n");
            printf(" Choice: ");

            char action = _getch();
            if (action == '1') {
                strcpy(p->holdingItem, p->items[idx]);
                printf("\n Stored into your hand: %s\n", p->holdingItem);
                saveToSlot(p, currentSlot);
                Sleep(1000);
                break;
            }
            else if (action == '2') {
                if (strcmp(p->items[idx], "Elixir") == 0) {
                    if (strcmp(p->holdingItem, p->items[idx]) == 0) {
                        strcpy(p->holdingItem, "None");
                    }
                    useElixirItem(p);
                    strcpy(p->items[idx], "Empty");
                    saveToSlot(p, currentSlot);
                    break;
                }
                else {
                    printf("\n This item cannot be consumed right now.\n");
                    Sleep(1000);
                }
            }
        }
    }
    system("cls"); drawMap(p); drawUI(p);
}

// ==========================
// Dynamic Puzzle Event Trigger
// ==========================
void triggerMansionPuzzle(Player* p) {
    system("cls");
    printf("==================================================\n");
    printf("          [PUZZLE] THE SEALED STONE DIAL          \n");
    printf("==================================================\n");
    printf(" A sequence is engraved: 2 -> 4 -> 8 -> 16 -> ?\n");
    printf(" Enter the next matching integer value: ");

    int attempt = 0;
    while (1) {
        int ans = 0;
        if (scanf("%d", &ans) != 1) {
            while (getchar() != '\n');
        }
        attempt++;

        if (ans == 32) {
            printf("\n Correct! The stone mechanisms click open.\n");
            if (attempt > 1) p->puzzleFirstTryFailed = 1;
            break;
        }
        else {
            p->totalPuzzleFailures++;
            printf(" Incorrect answer. The dial remains cold. Try again: ");
            if (p->totalPuzzleFailures >= 5) {
                unlockAchievement(p, 7);
            }
        }
    }
    printf("==================================================\n");
    printf(" Press any key to resume exploration... ");
    _getch();

    if (p->puzzleFirstTryFailed == 0) {
        unlockAchievement(p, 8);
    }

    system("cls");
    drawMap(p);
    drawUI(p);
}

