// Core Game Updates
// ==========================
void checkJournalEvent(Player* p) {
    int totalFound = 0;
    for (int i = 0; i < MAX_JOURNALS; i++) {
        if (p->collectedJournals[i] == 0) {
            if (p->floor == journalLocs[i].floor && p->x == journalLocs[i].x && p->y == journalLocs[i].y) {
                p->collectedJournals[i] = 1;
                system("cls");
                printf("==================================================\n");
                printf("          [!] DISCOVERED AN OLD JOURNAL           \n");
                printf("==================================================\n");
                printf("%s\n", journalTexts[i]);
                printf("==================================================\n");
                printf(" Progress Auto-Saved. Press any key to return... ");

                saveToSlot(p, currentSlot);
                _getch();
                system("cls");
                drawMap(p);
                drawUI(p);
            }
        }
        if (p->collectedJournals[i] == 1) totalFound++;
    }

    if (totalFound == MAX_JOURNALS) {
        unlockAchievement(p, 1);
    }
}

